{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "schedule": [
    "* * * * 0,6"
  ],
  "vulnerabilityAlerts": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchFileNames": ["examples/**/requirements.txt"],
      "matchUpdateTypes": ["minor", "patch"],
      "schedule": ["every 2 weeks"]
    }
  ]
}
