{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "automerge": true,
  "extends": [
    "config:recommended",
    "group:allNonMajor"
  ],
  "schedule": [
    "* * * * 0,6"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "baseBranches": ["$default", "v1"]
  },
  "packageRules": [
    {
      "matchFileNames": ["examples/**/charm/pyproject.toml"],
      "matchUpdateTypes": ["minor", "patch"],
      "schedule": ["* * 1,15 * *"]
    }
  ]
}
